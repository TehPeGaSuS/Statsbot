bot:
  nick: "statsbot"        # Default nick — can be overridden per network
  altnick: "statsbot_"    # Fallback if primary is taken
  realname: "IRC Stats Bot"
  ident: "statsbot"
  # Masters are configured via: python main.py --setup

networks:
  - name: "libera"
    host: "irc.libera.chat"
    port: 6697
    ssl: true
    channels:
      - "#yourchannel"
    # cmd_prefix: "."  # override global prefix for this network only

    # Authentication — uncomment and fill in what you need:

    # SASL PLAIN — preferred on modern networks (Libera, OFTC, etc.)
    # sasl:
    #   username: "statsbot"
    #   password: "your_password"

    # NickServ IDENTIFY — legacy, works on most networks
    # nickserv_password: "your_password"

    # Nick ghosting — reclaim primary nick via NickServ if taken
    # ghost: true
    # ghost_command: "GHOST"   # Use "RELEASE" for DALnet (default: GHOST)

    # Server password (for BNCs or private servers)
    # server_password: "your_password"

    # Per-network identity — overrides the global bot: defaults
    # nick: "ChanStatsBot"
    # altnick: "ChanStatsBot_"

    # Commands sent after 001 ({nick} = current bot nick)
    # on_connect:
    #   - "MODE {nick} +x"       # request cloak (Undernet, some others)

    # Channel join retries
    # join_retries: 5            # max attempts per channel (default: 5)
    # join_retry_delay: 30       # seconds between attempts (default: 30)

    # ── Per-channel pisg overrides ───────────────────────────────────────────
    # Any key from the global pisg: section below can be overridden per channel.
    # Changes here take effect after: /msg statsbot rehash
    # You can also set overrides live (no rehash needed) via PM:
    #   /msg statsbot pisg #channel set <key> <value>
    #   /msg statsbot pisg #channel reset [key]
    #   /msg statsbot pisg #channel list   ← get a link to view effective config
    #
    # channel_pisg:
    #   "#yourchannel":
    #     DailyActivity: 90      # show 90 days of activity instead of the global 30
    #     ShowVoice: true        # enable the voice section for this channel only
    #
    #   "#quietchannel":
    #     ActiveNicks: 10        # smaller top table — fewer regulars
    #     ShowBigNumbers: false  # disable the big numbers section entirely
    #     DailyActivity: 0       # disable daily activity graph for this channel

stats:
  # Nicks/masks permanently ignored — never tracked, never shown.
  # Supports nick patterns (*bot*, ChanServ) and full hostmasks (*!*@services.example.org)
  # Channel-specific ignores can be added at runtime via /msg statsbot ignore add #chan <pattern>
  ignore:
    - "ChanServ"
    - "NickServ"
    - "MemoServ"
    - "*Serv"
    - "*bot*"
    - "*Bot*"

  auto_ignore_bots: false   # auto-ignore nicks with IRC +B umode — unreliable, opt-in only
  expire_days: 30           # remove nicks unseen for X days (0 = never)
  log_wordstats: true       # track word frequency per nick
  quote_frequency: 5        # log every Nth message as a random quote
  kick_context: 5           # lines of context to save with each kick

  happy_smileys: [":-)", ":)", ";)", ";-)", "^_^", ":-D", ":-P", ":P", "=)", ";D",
                 ":D", "xD", "XD", ":3", "uwu", "owo"]

  sad_smileys: [":-(", ":(", ":'(", "):", "D:", "T_T", ";_;", "o_O", "O_o", ">_<",
                ":/", ":S"]

web:
  enabled: true
  host: "0.0.0.0"
  port: 8033
  public_url: ""            # e.g. https://stats.yourserver.org — used by !stats and pisg config links
  title: "IRC Stats"
  project_url: "https://github.com/TehPeGaSuS/Statsbot"

commands:
  prefix: "!"
  max_cmds: 5               # flood protection: max N commands
  max_cmds_window: 60       # ... per X seconds

database:
  path: "data/stats.db"

logging:
  level: "INFO"
  file: "data/ircstats.log"

pisg:
  # Daily activity chart
  DailyActivity: 30            # days to show in "Daily activity" graph (0 = disabled)

  # Main nick table
  ActiveNicks: 25              # rows in main top table
  ActiveNicks2: 10             # nicks in "These didn't make it to the top" list
  SortByWords: true            # sort by words (true) or lines (false)
  ShowWords: true
  ShowLines: true
  ShowWpl: true                # words per line column
  ShowCpl: false               # chars per line column
  ShowLastSeen: true
  ShowRandQuote: true
  MinQuote: 25                 # min chars for a quote to be picked
  MaxQuote: 65                 # max chars for a quote to be picked

  # Big numbers
  ShowBigNumbers: true
  BigNumbersThreshold: "sqrt"  # min lines to qualify, or "sqrt" for auto
  ViolentWords: ["slaps", "beats", "kicks", "hits", "smacks", "stabs", "hugs", "pokes"]
  FoulWords: ["ass", "fuck", "shit", "bitch", "cunt", "cock", "dick"]

  # Section toggles
  ShowMostActiveByHour: true
  ShowSmileys: true
  ShowMrn: true
  ShowOps: true
  ShowActiveTimes: true
  ShowActiveNicks: true
  ShowMuw: true
  ShowTopics: true
  ShowTime: true
  ShowMostActiveByHourGraph: true
  ShowVoice: false             # voice given/taken/received (disabled by default)
  ShowHalfops: false           # halfops section (disabled by default)
  ShowKarma: true
  KarmaHistory: 10
  ShowMru: true
  ShowLegend: true

  # History limits
  TopicHistory: 5
  UrlHistory: 10
  WordHistory: 10
  WordLength: 4
  IgnoreWords: []
  NickHistory: 5
  SmileyHistory: 10
  ActiveNicksByHour: 10
